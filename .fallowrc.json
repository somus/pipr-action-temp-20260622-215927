{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignoreDependencies": ["collections"],
  "entry": [
    ".pipr/config.ts",
    "packages/cli/src/main.ts",
    "packages/sdk/src/index.ts",
    "packages/runtime/src/index.ts",
    "packages/runtime/src/pi/runtime-tools-extension.ts",
    "scripts/act-action-fixture.ts"
  ],
  "ignorePatterns": [
    "**/dist/**",
    "**/coverage/**",
    ".turbo/**",
    "node_modules/**",
    "apps/docs/.source/**",
    "apps/docs/.output/**",
    "apps/docs/src/routeTree.gen.ts"
  ],
  "workspaces": {
    "patterns": ["apps/*", "packages/*"]
  },
  "duplicates": {
    "ignore": [
      "**/dist/**",
      "**/coverage/**",
      "apps/docs/.source/**",
      "apps/docs/.output/**",
      "apps/docs/src/routeTree.gen.ts"
    ]
  }
}
