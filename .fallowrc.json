{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "packages/cli/src/main.ts",
    "packages/runtime/src/index.ts",
    "packages/runtime/runtime-tools-extension.mjs"
  ],
  "ignorePatterns": ["**/dist/**", "**/coverage/**", ".turbo/**", "node_modules/**"],
  "workspaces": {
    "patterns": ["packages/*"]
  },
  "duplicates": {
    "ignore": ["**/dist/**", "**/coverage/**", "packages/runtime/runtime-tools-extension.mjs"]
  },
  "health": {
    "ignore": ["packages/runtime/runtime-tools-extension.mjs"]
  }
}
