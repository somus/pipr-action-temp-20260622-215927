{
  "name": "@pipr/sdk",
  "version": "0.1.0",
  "description": "TypeScript configuration SDK for pipr pull request review automation",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somus/pipr.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/somus/pipr/issues"
  },
  "homepage": "https://github.com/somus/pipr#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --dts --format esm --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src",
    "format:check": "biome check src",
    "prepack": "bun run build",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "devDependencies": {
    "vitest": "4.1.9"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
