{
  "name": "@pipr/sdk",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts --dts --format esm --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check src",
    "format:check": "biome check src",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "devDependencies": {
    "vitest": "4.1.9"
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
