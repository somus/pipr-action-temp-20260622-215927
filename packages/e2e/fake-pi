#!/usr/bin/env bun

import path from "node:path";
import { pathToFileURL } from "node:url";

const prompt = await readPrompt(process.argv.at(-1) ?? "");
const args = process.argv.slice(2, -1);

if (!prompt.includes("Diff Manifest:")) {
  throw new Error("fake-pi could not find Diff Manifest in prompt");
}

const piTelemetry = await beginPiTelemetry();
try {
  if (piTelemetry) {
    await delay(400);
  }
  console.log(JSON.stringify(await buildReview()));
} finally {
  await piTelemetry?.end();
}

async function buildReview() {
  if (prompt.includes("Specialist reviews:")) {
    return orchestratorReview();
  }
  if (prompt.includes("Focus: correctness")) {
    return specialistReview("correctness", "Correctness specialist review");
  }
  if (prompt.includes("Focus: security")) {
    return specialistReview("security", "Security specialist review");
  }
  if (prompt.includes("Focus: tests")) {
    return specialistReview("tests", "Tests specialist review");
  }
  if (prompt.includes('"mode": "condensed"')) {
    await assertCondensedRuntimeTools();
    return review("Condensed fixture review", "Condensed act fixture reached Pi after runtime tools passed.");
  }
  return fullFixtureReview();
}

async function readPrompt(value) {
  if (!value.startsWith("@")) {
    return value;
  }
  return await Bun.file(value.slice(1)).text();
}

async function fullFixtureReview() {
  assertPathScopePrompt();
  const manifest = parsePromptJson("\nManifest:");
  const ranges = manifest.files.flatMap((file) => file.commentableRanges ?? []);
  const range =
    ranges.find(
      (item) =>
        item.path === "packages/e2e/fixtures/act/project/sample.ts" &&
        item.side === "RIGHT" &&
        item.preview?.includes("normalized"),
    ) ??
    ranges.find(
      (item) => item.path === "packages/e2e/fixtures/act/project/sample.ts" && item.kind === "added",
    ) ??
    ranges.find(
      (item) => item.path === "packages/e2e/fixtures/act/project/sample.ts" && item.side === "RIGHT",
    );

  if (!range) {
    return review("Fixture review", "Fake Pi found no commentable ranges.");
  }

  return {
    summary: {
      title: "Fixture review",
      body: "Fake Pi reviewed the act full-flow fixture.",
    },
    inlineFindings: [
      {
        body: "Full-flow act reached inline publication.",
        path: range.path,
        rangeId: range.id,
        side: range.side,
        startLine: range.startLine,
        endLine: range.startLine,
      },
      ...outOfScopeFindings(range),
    ],
  };
}

function outOfScopeFindings(range) {
  if (!prompt.includes("Path scope:")) {
    return [];
  }
  return [
    {
      body: "Out-of-scope act path should not publish.",
      path: "docs/out-of-scope.md",
      rangeId: range.id,
      side: range.side,
      startLine: range.startLine,
      endLine: range.startLine,
    },
  ];
}

function assertPathScopePrompt() {
  if (!prompt.includes("Path scope:")) {
    return;
  }
  assert(
    prompt.includes('"packages/e2e/fixtures/act/project/**"'),
    "path-scoped prompt missing include glob",
  );
  assert(prompt.includes('"**/*.test.ts"'), "path-scoped prompt missing exclude glob");
  assert(
    prompt.includes("Read tools may access the whole repository."),
    "path-scoped prompt did not preserve whole-repo read access",
  );
}

function orchestratorReview() {
  assertPromptContains("Correctness specialist review");
  assertPromptContains("Security specialist review");
  assertPromptContains("Tests specialist review");
  const manifest = parsePromptJson("\nManifest:", "\nSpecialist reviews:");
  const file = manifest.files.find((item) => item.path === "packages/e2e/fixtures/act/project/sample.ts");
  assert(file, "orchestrator manifest missing sample file");
  const range =
    file.commentableRanges.find((item) => item.side === "RIGHT") ?? file.commentableRanges[0];
  assert(range, "orchestrator manifest missing commentable range");
  return {
    summary: {
      title: "Orchestrator fixture review",
      body: "Orchestrated review combined correctness, security, and tests specialist outputs.",
    },
    findings: [
      {
        body: "Orchestrator custom schema mapped a labeled finding into core inline output.",
        path: range.path,
        rangeId: range.id,
        side: range.side,
        startLine: range.startLine,
        endLine: range.startLine,
        severity: "medium",
      },
    ],
  };
}

function specialistReview(focus, summary) {
  return { focus, summary };
}

async function assertCondensedRuntimeTools() {
  const toolNames = readFlagValue("--tools");
  const extensionPath = readFlagValue("--extension");
  const dataPath = Bun.env.PIPR_RUNTIME_TOOLS_DATA;

  assertEqual(
    toolNames,
    "read,grep,find,ls,pipr_read_diff,pipr_read_at_ref",
    "unexpected condensed Pi tool allowlist",
  );
  for (const forbidden of ["bash", "edit", "write"]) {
    assert(!toolNames.split(",").includes(forbidden), `forbidden tool '${forbidden}' was enabled`);
  }
  assert(await Bun.file(extensionPath).exists(), "runtime tool extension path missing");
  assertEqual(path.basename(extensionPath), "runtime-tools-extension.mjs", "runtime tool extension was not static");
  assert(dataPath, "runtime tool data env missing");
  assert(await Bun.file(dataPath).exists(), "runtime tool data path missing");
  assertEqual(path.basename(dataPath), "data.json", "runtime tool data file name mismatch");

  const payload = parsePromptJson("\nPayload:", "\nManifest:");
  assertEqual(payload.mode, "condensed", "expected condensed manifest payload");
  assert(prompt.includes("pipr_read_diff(path?, rangeId?)"), "prompt did not describe pipr_read_diff");
  assert(
    prompt.includes("pipr_read_at_ref(path, ref, rangeId?)"),
    "prompt did not describe pipr_read_at_ref",
  );

  const manifest = parsePromptJson("\nManifest:");
  const file = manifest.files.find((item) => item.path === "packages/e2e/fixtures/act/project/sample.ts");
  assert(file, "condensed manifest missing sample file");
  assert(file.commentableRanges.length > 0, "condensed manifest missing commentable ranges");
  assert(!("preview" in file.commentableRanges[0]), "condensed range kept preview");

  const range =
    file.commentableRanges.find((item) => item.side === "RIGHT") ?? file.commentableRanges[0];
  for (const key of [
    "id",
    "path",
    "side",
    "startLine",
    "endLine",
    "kind",
    "hunkHeader",
    "hunkContentHash",
  ]) {
    assert(range[key] !== undefined, `condensed range missing ${key}`);
  }

  const tools = await loadRuntimeTools(extensionPath);
  const diffTool = assertTool(tools, "pipr_read_diff");
  const atRefTool = assertTool(tools, "pipr_read_at_ref");
  const leftRange = file.commentableRanges.find((item) => item.side === "LEFT");
  assert(leftRange, "condensed manifest missing LEFT range for base read");

  const diffByPath = await executeTool(diffTool, { path: file.path });
  assertEqual(diffByPath.value.files.length, 1, "pipr_read_diff path filter returned wrong file count");
  assertEqual(diffByPath.value.files[0].path, file.path, "pipr_read_diff returned wrong path");
  assert(
    diffByPath.value.files[0].commentableRanges.some((item) => item.preview?.includes("normalized")),
    "pipr_read_diff did not return full range preview",
  );

  const diffByRange = await executeTool(diffTool, { rangeId: range.id });
  assertEqual(
    diffByRange.value.files[0].commentableRanges.length,
    1,
    "pipr_read_diff range filter returned wrong range count",
  );
  assertEqual(
    diffByRange.value.files[0].commentableRanges[0].id,
    range.id,
    "pipr_read_diff returned wrong range",
  );

  const headContent = await executeTool(atRefTool, {
    path: file.path,
    ref: "head",
    rangeId: range.id,
  });
  assert(headContent.content.includes("normalized"), "pipr_read_at_ref head read missed head content");
  assertEqual(headContent.path, file.path, "pipr_read_at_ref head path mismatch");

  const baseContent = await executeTool(atRefTool, {
    path: file.path,
    ref: "base",
    rangeId: leftRange.id,
  });
  assert(baseContent.content.includes("legacy.trim()"), "pipr_read_at_ref base read missed base content");
  assertEqual(baseContent.path, file.path, "pipr_read_at_ref base path mismatch");

  const oppositeSideBase = await executeTool(atRefTool, {
    path: file.path,
    ref: "base",
    rangeId: range.id,
  });
  assertEqual(oppositeSideBase.available, false, "pipr_read_at_ref widened opposite-side base read");

  await assertRejects(
    () => executeTool(diffTool, { path: "packages/e2e/fixtures/act/project/missing.ts" }),
    "not in the Diff Manifest",
  );
  await assertRejects(() => executeTool(diffTool, { rangeId: "rng_missing" }), "Unknown Diff Manifest range");
  await assertRejects(
    () => executeTool(atRefTool, { path: "../sample.ts", ref: "head", rangeId: range.id }),
    "Unsafe manifest path",
  );
  await assertRejects(
    () => executeTool(atRefTool, { path: file.path, ref: "topic", rangeId: range.id }),
    "Unsupported ref",
  );
  await assertRejects(
    () => executeTool(atRefTool, { path: file.path, ref: "head", rangeId: "rng_missing" }),
    "Unknown Diff Manifest range",
  );
}

function review(title, body) {
  return {
    summary: { title, body },
    inlineFindings: [],
  };
}

function readFlagValue(flag) {
  const index = args.indexOf(flag);
  assert(index !== -1 && args[index + 1] !== undefined, `${flag} missing`);
  return args[index + 1];
}

function parsePromptJson(startLabel, endLabel) {
  const start = prompt.indexOf(startLabel);
  assert(start !== -1, `prompt missing ${startLabel}`);
  const contentStart = start + startLabel.length;
  if (endLabel !== undefined) {
    return parseFirstJsonValue(prompt.slice(contentStart));
  }
  const end =
    endLabel === undefined
      ? readNextPromptSectionIndex(contentStart)
      : prompt.indexOf(endLabel, contentStart);
  assert(end !== -1, `prompt missing ${endLabel}`);
  return JSON.parse(prompt.slice(contentStart, end).trim());
}

function readNextPromptSectionIndex(contentStart) {
  const markers = [
    "\n\nCondensed manifest helper tools:",
    "\n\nInstructions:",
    "\n\nRun Instructions:",
    "\n\nPrior pipr findings:",
    "\n\nPrompt:",
  ]
    .map((marker) => prompt.indexOf(marker, contentStart))
    .filter((index) => index !== -1);
  return markers.length > 0 ? Math.min(...markers) : prompt.length;
}

function parseFirstJsonValue(value) {
  const trimmed = value.trimStart();
  let depth = 0;
  let inString = false;
  let escaped = false;
  for (let index = 0; index < trimmed.length; index += 1) {
    const char = trimmed[index];
    if (inString) {
      escaped = char === "\\" && !escaped;
      if (char === '"' && !escaped) {
        inString = false;
      }
      if (char !== "\\") {
        escaped = false;
      }
      continue;
    }
    if (char === '"') {
      inString = true;
      continue;
    }
    if (char === "{" || char === "[") {
      depth += 1;
    } else if (char === "}" || char === "]") {
      depth -= 1;
      if (depth === 0) {
        return JSON.parse(trimmed.slice(0, index + 1));
      }
    }
  }
  throw new Error("prompt JSON value was incomplete");
}

async function loadRuntimeTools(extensionPath) {
  const registered = new Map();
  const extension = await import(pathToFileURL(extensionPath).href);
  await extension.default({
    registerTool(tool) {
      registered.set(tool.name, tool);
    },
  });
  return registered;
}

function assertTool(tools, name) {
  const tool = tools.get(name);
  assert(tool, `runtime tool ${name} was not registered`);
  return tool;
}

async function executeTool(tool, params) {
  const result = await tool.execute("act-fixture", params, undefined, undefined, { cwd: process.cwd() });
  return result.details ?? JSON.parse(result.content[0].text);
}

async function assertRejects(run, expectedMessage) {
  try {
    await run();
  } catch (error) {
    assert(
      error instanceof Error && error.message.includes(expectedMessage),
      `expected rejection '${expectedMessage}', got '${error instanceof Error ? error.message : String(error)}'`,
    );
    return;
  }
  throw new Error(`expected rejection '${expectedMessage}'`);
}

function assertPromptContains(value) {
  if (!prompt.includes(value)) {
    throw new Error(`orchestrator prompt missing ${value}`);
  }
}

function assertEqual(actual, expected, message) {
  assert(actual === expected, `${message}: expected ${expected}, got ${actual}`);
}

function assert(condition, message) {
  if (!condition) {
    throw new Error(message);
  }
}

async function beginPiTelemetry() {
  const directory = Bun.env.PIPR_ACT_PI_CALL_DIR ?? telemetryDirectoryFromProviderEnv();
  if (!directory) {
    return undefined;
  }
  run("mkdir", ["-p", directory]);
  const id = `${Date.now()}-${process.pid}-${crypto.randomUUID()}`;
  const file = `${directory}/${id}.jsonl`;
  await appendTelemetry(file, { id, phase: "start", time: Date.now(), promptKind: promptKind() });
  return {
    end: () =>
      appendTelemetry(file, { id, phase: "end", time: Date.now(), promptKind: promptKind() }),
  };
}

async function appendTelemetry(file, event) {
  const telemetry = Bun.file(file);
  const existing = (await telemetry.exists()) ? await telemetry.text() : "";
  await Bun.write(file, `${existing}${JSON.stringify(event)}\n`);
}

function run(command, args) {
  const result = Bun.spawnSync([command, ...args], {
    stderr: "inherit",
    stdout: "inherit",
  });
  if (result.exitCode !== 0) {
    throw new Error(`${command} ${args.join(" ")} failed with exit ${result.exitCode}`);
  }
}

function telemetryDirectoryFromProviderEnv() {
  const providerEnvName = Bun.env.PIPR_PROVIDER_API_KEY_ENV;
  if (!providerEnvName) {
    return undefined;
  }
  const value = Bun.env[providerEnvName];
  return value?.includes("/packages/e2e/fixtures/act/pi-calls-") ? value : undefined;
}

function promptKind() {
  if (prompt.includes("Specialist reviews:")) {
    return "orchestrator";
  }
  if (prompt.includes("Focus: correctness")) {
    return "correctness";
  }
  if (prompt.includes("Focus: security")) {
    return "security";
  }
  if (prompt.includes("Focus: tests")) {
    return "tests";
  }
  if (prompt.includes('"mode": "condensed"')) {
    return "condensed";
  }
  return "full";
}

function delay(milliseconds) {
  return new Promise((resolve) => setTimeout(resolve, milliseconds));
}
