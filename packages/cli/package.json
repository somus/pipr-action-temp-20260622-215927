{
  "name": "@pipr/cli",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "bin": {
    "pipr": "./src/main.ts"
  },
  "scripts": {
    "build": "bun run --cwd ../runtime build && tsdown src/main.ts --dts --format esm --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun run --cwd ../runtime build && bun test",
    "lint": "biome check src",
    "format:check": "biome check src",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@pipr/runtime": "workspace:*",
    "commander": "15.0.0"
  }
}
