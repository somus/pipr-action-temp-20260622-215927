{
  "name": "@pipr/runtime",
  "version": "0.1.1",
  "description": "Runtime package for pipr pull request review automation",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somus/pipr.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/somus/pipr/issues"
  },
  "homepage": "https://github.com/somus/pipr#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./e2e/action-fixture": {
      "types": "./dist/e2e/action-fixture.d.mts",
      "default": "./dist/e2e/action-fixture.mjs"
    },
    "./e2e/pi-contract": {
      "types": "./dist/e2e/pi-contract.d.mts",
      "default": "./dist/e2e/pi-contract.mjs"
    },
    "./runtime-tools-extension": {
      "types": "./dist/pi/runtime-tools-extension.d.mts",
      "default": "./dist/pi/runtime-tools-extension.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/e2e/action-fixture.ts src/e2e/pi-contract.ts src/pi/runtime-tools-extension.ts --dts --format esm --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 60000",
    "lint": "biome check src",
    "format:check": "biome check src",
    "prepack": "bun run build",
    "check": "bun run lint && bun run typecheck && bun run test"
  },
  "dependencies": {
    "@octokit/rest": "22.0.1",
    "@pipr/sdk": "0.1.1",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "lodash-es": "4.18.1",
    "picomatch": "4.0.4",
    "pino": "10.3.1",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "@types/picomatch": "4.0.3"
  }
}
