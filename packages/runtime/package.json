{
  "name": "@pipr/runtime",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./runtime-tools-extension": {
      "types": "./dist/pi/runtime-tools-extension.d.mts",
      "default": "./dist/pi/runtime-tools-extension.mjs"
    }
  },
  "scripts": {
    "build": "bun run --cwd ../sdk build && tsdown src/index.ts src/action/fixture-dependencies.ts src/pi/runtime-tools-extension.ts --dts --format esm --out-dir dist",
    "typecheck": "bun run --cwd ../sdk build && tsc --noEmit",
    "test": "bun run --cwd ../sdk build && vitest run",
    "lint": "biome check src",
    "format:check": "biome check src",
    "check": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@octokit/rest": "22.0.1",
    "@pipr/sdk": "workspace:*",
    "lodash-es": "4.18.1",
    "picomatch": "4.0.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/lodash-es": "4.17.12",
    "@types/picomatch": "4.0.3",
    "vitest": "4.1.9"
  }
}
