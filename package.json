{
  "name": "pipr",
  "version": "0.1.1",
  "description": "Pi-powered GitHub pull request review runtime",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/somus/pipr.git"
  },
  "bugs": {
    "url": "https://github.com/somus/pipr/issues"
  },
  "homepage": "https://github.com/somus/pipr#readme",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "fallow": "fallow --fail-on-issues --format compact",
    "build:release:cli": "bun packages/cli/build-release.ts",
    "sync:release-lockfile": "bun scripts/sync-release-lockfile.ts",
    "hooks-install": "hk install --mise",
    "check:release-metadata": "bun scripts/check-release-metadata.ts",
    "check:conventional-commit": "bun scripts/check-conventional-commit.ts --message \"chore: validate conventional commit check\"",
    "check:scripts": "bun test scripts/tests",
    "check": "bun run check:release-metadata && bun run check:conventional-commit && bun run check:scripts && turbo run lint typecheck test build //#format:check //#fallow",
    "check:actions": "bun run --cwd packages/e2e check:actions"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "fallow": "2.97.0",
    "tsdown": "0.22.3",
    "turbo": "2.9.18",
    "typescript": "catalog:"
  }
}
