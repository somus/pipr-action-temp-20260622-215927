{
  "name": "pipr",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "fallow": "fallow --fail-on-issues --format compact",
    "check": "turbo run lint typecheck test build //#format:check //#fallow",
    "check:actions": "bun run --cwd packages/e2e check:actions"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.3",
    "fallow": "2.97.0",
    "tsdown": "0.22.3",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
